compute_log_rr_se <- function(n_exposed, events_exposed, n_unexposed, events_unexposed) {
# Non-events
non_events_exposed <- n_exposed - events_exposed
non_events_unexposed <- n_unexposed - events_unexposed
# Check for 0 events to avoid division by zero
if (events_exposed == 0 || events_unexposed == 0) {
stop("Cannot compute SE: zero events in one or both groups.")
}
# Compute standard error of log(RR)
se_log_rr <- sqrt(
(1 / events_exposed) - (1 / n_exposed) +
(1 / events_unexposed) - (1 / n_unexposed)
)
# compute ci based on nomral approximation
ci.lower <- exp(log(events_exposed / events_unexposed) - 1.96 * se_log_rr)
ci.upper <- exp(log(events_exposed / events_unexposed) + 1.96 * se_log_rr)
return(se_log_rr)
}
n_exposed <- 1144
n_unexposed <- 1144
events.exposed <- 0.2*1144
events.unexposed <- 0.25*1144
compute_log_rr_se(n_exposed, events.exposed, n_unexposed, events.unexposed)
